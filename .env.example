# Movie Recommendation API — Environment Template
# ==========================================================================
# Copy this file to '.env' and fill in your credentials.
# The application loads these variables via 'dotenv' at runtime.

# --- Database (PostgreSQL) ---
# Async connection URL used by the application
DATABASE_URL=postgresql+asyncpg://cinewave:cinewave_secret@localhost:5432/cinewave_db
# Sync connection URL used by Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg2://cinewave:cinewave_secret@localhost:5432/cinewave_db
# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=cinewave
POSTGRES_PASSWORD=cinewave_secret
POSTGRES_DB=cinewave_db

# --- Authentication ---
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=replace_me_with_a_secure_hex_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Initial Superuser (created automatically on first run)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin_password_here
INITIAL_ADMIN_EMAIL=admin@example.com

# --- External Services ---
# Get your API key from: https://www.themoviedb.org/settings/api
API_KEY=your_tmdb_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
